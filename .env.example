# =============================================================================
# DataSUS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=datasus
POSTGRES_PASSWORD=datasus_secret
POSTGRES_DB=datasus_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRIAGEM=triagem-eventos
KAFKA_TOPIC_ALERTAS=alertas-risco

# --- Spark ---
SPARK_MASTER=local[*]
SPARK_APP_NAME=datasus-pipeline

# --- Paths de dados ---
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed

# --- Ingestão (container `ingestor`) ---
# UFs alvo, separadas por vírgula. Default: RS.
INGEST_UFS=RS
# Primeira competência a baixar no backfill (AAAA-MM). Default: 2022-01.
INGEST_COMPETENCIA_INICIAL=2022-01
# Lag em meses entre o mês corrente e a competência mais recente do FTP. Default: 2.
INGEST_LAG_MESES=2
