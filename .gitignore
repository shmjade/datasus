# =============================================================================
# DataSUS — .gitignore
# =============================================================================

# --- Dados brutos e processados (nunca versionar dados grandes) ---
data/raw/
data/processed/
data/lake/
data/downloads/
data/samples/
*.parquet
*.dbf
*.dbc

# CSVs em geral (gerados): bloqueia exceto data/ibge/
*.csv
!data/ibge/*.csv

# Mas exclui os "raw" baixados (grandes, regeneráveis via scripts/download_*.py):
data/ibge/idhm_brasil_raw.csv
data/ibge/poa_pop_bairro_raw.csv

# --- Ambiente Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.env
*.egg-info/
dist/
build/
.eggs/

# --- Secrets e variáveis de ambiente ---
.env
.env.local
.env.*.local

# --- Jupyter Notebooks (outputs) ---
notebooks/**/*.ipynb
!notebooks/**/.gitkeep
.ipynb_checkpoints/

# --- IDEs ---
.idea/
.vscode/settings.json
*.swp
*.swo

# --- macOS ---
.DS_Store
Thumbs.db

# --- Docker volumes locais ---
infra/volumes/

# --- Logs ---
*.log
logs/

# --- Docs auto-gerados (regenerar com scripts/gen_*.py; podem conter CNPJs reais) ---
docs/data_dict.html
docs/data_dict.json
docs/datasets_dic.html

# --- mypy ---
.mypy_cache/

# --- pytest ---
.pytest_cache/
htmlcov/
.coverage

# --- Spark ---
derby.log
metastore_db/
spark-warehouse/
